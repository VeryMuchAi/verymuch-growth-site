# ── GHL ─────────────────────────────────────────────────────────────────────
# GoHighLevel workflow webhook URL.
# The /api/lead route will POST the lead payload to this URL on each submission.
# Leave empty to use mock mode (payload logged to console only).
GHL_WEBHOOK_URL=

# ── Notion / Guide URLs ──────────────────────────────────────────────────────
# Public Notion URL shown in the success state of signals-linkedin lead magnet.
# Stays server-side — never exposed in the client bundle.
NOTION_URL=
NOTION_URL_6_AGENTES=
NOTION_URL_CLAUDE_CODE_REMOTE_CONTROL=

# ── Site ─────────────────────────────────────────────────────────────────────
# Used for absolute URLs in OG metadata (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://verymuch.ai
